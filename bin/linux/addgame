#!/usr/bin/env python3
import os
import sys
import vdf
import psutil
import glob
import zlib

def get_steam_path():
    return os.path.expanduser("~/.local/share/Steam")

def get_shortcuts_path():
    steam_path = get_steam_path()
    userdata_path = os.path.join(steam_path, "userdata")
    shortcuts_files = glob.glob(os.path.join(userdata_path, "*", "config", "shortcuts.vdf"))
    if not shortcuts_files:
        return None
    return max(shortcuts_files, key=os.path.getmtime)

def get_config_path():
    return os.path.expanduser("~/.local/share/Steam/config/config.vdf")

def is_steam_running():
    for proc in psutil.process_iter(['name']):
        if proc.info['name'] == 'steam':
            return True
    return False

def calculate_appid(exe, name):
    s = exe + name
    return str(zlib.crc32(s.encode('utf-8')) | 0x80000000)

def add_game(name, exe_path):
    shortcuts_path = get_shortcuts_path()
    config_path = get_config_path()
    if not shortcuts_path or not os.path.exists(config_path):
        print("Error: Could not find Steam configuration files.")
        sys.exit(1)

    if is_steam_running():
        print("Error: Steam is running. Please close Steam before adding games.")
        sys.exit(1)

    abs_exe = os.path.abspath(exe_path)
    q_exe = f'"{abs_exe}"'
    start_dir = f'"{os.path.dirname(abs_exe)}/"'

    with open(shortcuts_path, "rb") as f:
        s_data = vdf.binary_load(f)

    if 'shortcuts' not in s_data:
        s_data['shortcuts'] = {}

    indices = [int(k) for k in s_data['shortcuts'].keys()]
    next_index = str(max(indices) + 1 if indices else 0)

    for s in s_data['shortcuts'].values():
        if s.get('AppName') == name or s.get('Exe') == q_exe:
            print(f"Warning: Game '{name}' already exists in Steam.")
            break
    else:
        new_shortcut = {
            "AppName": name,
            "Exe": q_exe,
            "StartDir": start_dir,
            "icon": "",
            "ShortcutPath": "",
            "LaunchOptions": "",
            "IsHidden": 0,
            "AllowDesktopConfig": 1,
            "AllowOverlay": 1,
            "OpenVR": 0,
            "Devkit": 0,
            "DevkitGameID": "",
            "DevkitOverrideAppID": 0,
            "LastPlayTime": 0,
            "FlatpakAppID": "",
            "tags": {}
        }
        s_data['shortcuts'][next_index] = new_shortcut
        with open(shortcuts_path, "wb") as f:
            vdf.binary_dump(s_data, f)

    appid = calculate_appid(q_exe, name)

    with open(config_path, "r") as f:
        c_data = vdf.load(f)

    try:
        mapping = c_data['InstallConfigStore']['Software']['Valve']['Steam']['CompatToolMapping']
    except KeyError:
        print("Error: Could not find CompatToolMapping in config.vdf")
        sys.exit(1)

    mapping[appid] = {
        "name": "proton_11",
        "config": "",
        "priority": "250"
    }

    with open(config_path, "w") as f:
        vdf.dump(c_data, f, pretty=True)

    print(f"Success: '{name}' (ID: {appid}) added with Proton 11 forced.")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print('Usage: addgame "Game Name" "/path/to/game.exe"')
        sys.exit(1)
    add_game(sys.argv[1], sys.argv[2])
